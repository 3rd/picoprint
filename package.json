{
  "name": "picoprint",
  "version": "2.1.0",
  "description": "Tiny zero-dependency pretty printer for the terminal",
  "author": "3rd",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/3rd/picoprint.git"
  },
  "bugs": {
    "url": "https://github.com/3rd/picoprint/issues"
  },
  "homepage": "https://github.com/3rd/picoprint#readme",
  "keywords": [
    "pretty-print",
    "console",
    "terminal",
    "color",
    "formatting",
    "cli",
    "debug",
    "inspect",
    "diff",
    "table",
    "tree",
    "box"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "bun run build:clean && bun run build:esm && bun run build:cjs && bun run build:types",
    "build:clean": "rm -rf dist",
    "build:esm": "bun build src/index.ts --outfile=dist/index.mjs --format=esm --target=node",
    "build:cjs": "bun build src/index.ts --outfile=dist/index.cjs --format=cjs --target=node && bun scripts/fix-cjs-default.mjs",
    "build:types": "tsc --project tsconfig.build.json && bun scripts/fix-dts-imports.mjs",
    "prepublishOnly": "bun run test:package",
    "test": "bun test",
    "test:package": "bun run build && node scripts/package-smoke.mjs",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit",
    "knip": "knip"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "knip": "^6.1.0",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=22"
  }
}
