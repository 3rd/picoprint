{
  "name": "picoprint",
  "version": "2.2.0",
  "description": "Tiny zero-dependency pretty printer for the terminal",
  "author": "3rd",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/3rd/picoprint.git"
  },
  "bugs": {
    "url": "https://github.com/3rd/picoprint/issues"
  },
  "homepage": "https://github.com/3rd/picoprint#readme",
  "keywords": [
    "pretty-print",
    "console",
    "terminal",
    "color",
    "formatting",
    "debug",
    "inspect",
    "diff",
    "table",
    "tree",
    "box"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepack": "bun run build",
    "prepublishOnly": "bun run test:package",
    "test": "bun test",
    "test:package": "bun run build && node scripts/package-smoke.mjs",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit",
    "knip": "knip"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "knip": "^6.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=22",
    "bun": ">=1.1.0"
  }
}
